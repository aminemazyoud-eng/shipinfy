generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  stores    Store[]
}

model Store {
  id                          String         @id @default(cuid())
  warehouseId                 String
  warehouse                   Warehouse      @relation(fields: [warehouseId], references: [id])
  destinationAddress          String
  destinationDistrict         String
  destinationAddressLatitude  Float
  destinationAddressLongitude Float
  contacts                    StoreContact[]
}

model CsvExport {
  id            String   @id @default(cuid())
  filename      String
  warehouseName String
  nbTournees    Int
  csvContent    String
  createdAt     DateTime @default(now())
}

model StoreContact {
  id                      String @id @default(cuid())
  storeId                 String
  store                   Store  @relation(fields: [storeId], references: [id])
  destinationFirstname    String
  destinationLastname     String
  destinationEmailAddress String
  destinationMobileNumber String
}

model ShipperReference {
  code      String   @id
  createdAt DateTime @default(now())
}

model DeliveryReport {
  id         String          @id @default(cuid())
  filename   String
  uploadedAt DateTime        @default(now())
  isActive   Boolean         @default(true)
  orders     DeliveryOrder[]
}

model ScheduledReport {
  id           String   @id @default(cuid())
  reportId     String
  emails       String
  frequency    String
  time         String
  dayOfWeek    Int?
  dayOfMonth   Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DeliveryOrder {
  id                          String         @id @default(cuid())
  reportId                    String
  report                      DeliveryReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  externalReference           String?
  shipperReference            String?
  carrierReference            String?

  pickupTimeStart             DateTime?
  deliveryTimeStart           DateTime?
  deliveryTimeEnd             DateTime?

  dateTimeWhenOrderSent       DateTime?
  dateTimeWhenAssigned        DateTime?
  dateTimeWhenInTransport     DateTime?
  dateTimeWhenStartDelivery   DateTime?
  dateTimeWhenDelivered       DateTime?
  dateTimeWhenNoShow          DateTime?
  dateTimeLastUpdate          DateTime?

  shippingWorkflowStatus      String?
  paymentOnDeliveryAmount     Float?

  destinationFirstname        String?
  destinationLastname         String?
  destinationCityCode         String?
  destinationLongitude        Float?
  destinationLatitude         Float?

  originHubName               String?
  originHubCode               String?
  originHubCity               String?
  originHubLongitude          Float?
  originHubLatitude           Float?

  sprintName                  String?
  sprintGeoLongitude          Float?
  sprintGeoLatitude           Float?

  createdAt                   DateTime @default(now())

  @@index([reportId])
  @@index([shippingWorkflowStatus])
  @@index([dateTimeWhenOrderSent])
  @@index([deliveryTimeStart])
  @@index([sprintName])
  @@index([originHubName])
}
